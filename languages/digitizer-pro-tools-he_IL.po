msgstr "כותרת הבאנר"

msgid "Banner message"
msgstr "הודעת הבאנר"

msgid "Basic HTML is allowed: <strong>, <em>, <a>, <br>"
msgstr "ניתן להשתמש ב-HTML בסיסי: <strong>, <em>, <a>, <br>"

