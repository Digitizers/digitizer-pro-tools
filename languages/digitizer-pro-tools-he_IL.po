msgstr "טשטוש (פיקסלים)"

msgid "Vertical offset (px)"
msgstr "הזזה אנכית (פיקסלים)"

msgid "Content"
msgstr "תוכן"

msgid "Text color"
msgstr "צבע טקסט"

msgid "Button Design"
msgstr "עיצוב כפתורים"

msgid "Show button"
msgstr "הצגת הכפתור"

msgid "Hover background color"
msgstr "צבע רקע ב-Hover"

msgid "Border"
msgstr "מסגרת"

msgid "Adds a thin border in the text color."
msgstr "מוסיף מסגרת דקה בצבע הטקסט."

msgid "Cookie Categories"
msgstr "קטגוריות עוגיות"

msgid "Each category shows a separate toggle on the advanced-preferences screen. Scripts from the \"Scripts\" tab load only after the visitor consents to the matching category. Category names and descriptions are edited per language on the \"Texts\" tab."
msgstr "כל קטגוריה מציגה מתג נפרד במסך ההעדפות המתקדמות. סקריפטים מהטאב \"סקריפטים\" נטענים רק לאחר שהמבקר מסכים לקטגוריה המתאימה. שמות ותיאורי הקטגוריות נערכים לפי שפה בטאב \"טקסטים\"."

msgid "Essential cookies"
msgstr "עוגיות חיוניות"

msgid "Always active - cannot be disabled."
msgstr "תמיד פעילות - לא ניתן לבטל."

msgid "Functional cookies"
msgstr "עוגיות פונקציונליות"

msgid "Analytics cookies"
msgstr "עוגיות אנליטיקה"

msgid "Marketing cookies"
msgstr "עוגיות שיווק"

msgid "Scripts loaded after consent"
msgstr "סקריפטים שנטענים לאחר הסכמה"

msgid "How does it work?"
msgstr "איך זה עובד?"

msgid "Paste the full HTML snippets here (Google Analytics, Facebook Pixel, GTM...). They are injected into the site <head> only after the visitor consents to the matching category."
msgstr "הדביקו כאן את קטעי ה-HTML המלאים (Google Analytics, Facebook Pixel, GTM...). הם מוזרקים ל-<head> של האתר רק לאחר שהמבקר מסכים לקטגוריה המתאימה."

msgid "Paste the complete code including the <script> tags."
msgstr "יש להדביק את הקוד המלא כולל תגיות <script>."

msgid "Functional scripts"
msgstr "סקריפטים פונקציונליים"

msgid "Analytics scripts"
msgstr "סקריפטים של אנליטיקה"

msgid "For example: Google Analytics 4, Google Tag Manager, Hotjar, Clarity."
msgstr "לדוגמה: Google Analytics 4, Google Tag Manager, Hotjar, Clarity."

msgid "Marketing scripts"
msgstr "סקריפטים של שיווק"

msgid "For example: Facebook Pixel, Google Ads, TikTok Pixel, LinkedIn Insight."
msgstr "לדוגמה: Facebook Pixel, Google Ads, TikTok Pixel, LinkedIn Insight."

msgid "Floating \"Manage Cookies\" Button"
msgstr "כפתור ניהול עוגיות צף"

msgid "A small button in the corner of the site that lets visitors reopen the banner and change their preferences at any time. Its text and accessibility label are edited per language on the \"Texts\" tab."
msgstr "כפתור קטן בפינת האתר שמאפשר למבקרים לפתוח את הבאנר מחדש ולשנות העדפות בכל עת. הטקסט ותווית הנגישות שלו נערכים לפי שפה בטאב \"טקסטים\"."

msgid "Basics"
msgstr "הגדרות בסיס"

msgid "Enable button"
msgstr "הפעלת הכפתור"

msgid "Anchor corner"
msgstr "פינת עוגן"

msgid "Top-right corner"
msgstr "פינה ימנית עליונה"

msgid "Top-left corner"
msgstr "פינה שמאלית עליונה"

msgid "The final position is the corner plus the offsets below."
msgstr "המיקום הסופי הוא הפינה ועוד המרחקים שבהמשך."

msgid "Desktop position"
msgstr "מיקום במחשב"

msgid "Offsets are measured from the chosen corner. For example, corner \"bottom-right\" with vertical offset 100 places the button 100px above the bottom - handy for avoiding WhatsApp/chat buttons."
msgstr "המרחקים נמדדים מהפינה שנבחרה. לדוגמה: פינה ימנית תחתונה עם מרחק אנכי 100 ממקמת את הכפתור 100 פיקסלים מעל התחתית - שימושי כדי לא להתנגש בכפתורי WhatsApp/צ'אט."

msgid "Horizontal offset"
msgstr "מרחק אופקי"

msgid "Vertical offset"
msgstr "מרחק אנכי"

msgid "Tip: WhatsApp buttons usually sit 20-80px from the bottom. Use 90-100 to avoid collisions."
msgstr "טיפ: כפתורי WhatsApp יושבים בדרך כלל 20-80 פיקסלים מהתחתית. השתמשו ב-90-100 כדי להימנע מהתנגשות."

msgid "Button size"
msgstr "גודל הכפתור"

msgid "Mobile position"
msgstr "מיקום במובייל"

msgid "Separate values for screens up to 640px wide."
msgstr "ערכים נפרדים למסכים ברוחב עד 640 פיקסלים."

msgid "Preview"
msgstr "תצוגה מקדימה"

msgid "Updates after saving."
msgstr "מתעדכן לאחר שמירה."

msgid "View banner on the site"
msgstr "צפייה בבאנר באתר"

msgid "Multilingual cookie-consent banner with cookie categories, script blocking until consent, and a floating preferences button."
msgstr "באנר הסכמת עוגיות רב-לשוני עם קטגוריות עוגיות, חסימת סקריפטים עד להסכמה וכפתור העדפות צף."

msgid "Site Tweaks"
msgstr "התאמות אתר"

msgid "Small site-wide tweaks, each an independent toggle. Replaces the assorted functions.php snippets."
msgstr "התאמות קטנות לכל האתר, כל אחת מתג עצמאי. מחליף את קטעי הקוד השונים של functions.php."

msgid "HTTP security headers"
msgstr "כותרות אבטחה של HTTP"

msgid "Sent on front-end responses. Verify with your browser dev tools after enabling."
msgstr "נשלחות בתגובות בצד הקדמי. יש לוודא בכלי הפיתוח של הדפדפן לאחר ההפעלה."

msgid "X-Frame-Options: SAMEORIGIN"
msgstr "X-Frame-Options: SAMEORIGIN"

msgid "Stops other sites from framing yours (clickjacking protection)."
msgstr "מונע מאתרים אחרים למסגר את האתר שלך (הגנה מפני clickjacking)."

msgid "X-Content-Type-Options: nosniff"
msgstr "X-Content-Type-Options: nosniff"

msgid "Stops browsers from MIME-sniffing responses."
msgstr "מונע מדפדפנים לנחש את סוג התוכן (MIME sniffing) של תגובות."

msgid "X-XSS-Protection"
msgstr "X-XSS-Protection"

msgid "<em>Legacy.</em> Deprecated and ignored by modern browsers; included only for parity with old snippets."
msgstr "<em>מיושן.</em> הוצא משימוש ומתעלמים ממנו בדפדפנים מודרניים; נכלל רק לצורך התאמה לקטעי קוד ישנים."

msgid "Strict-Transport-Security (HSTS)"
msgstr "Strict-Transport-Security (HSTS)"

msgid "Forces HTTPS for a year. <strong>Only enable once HTTPS is solid</strong> - browsers cache this and it is hard to undo. Sent over HTTPS only."
msgstr "כופה HTTPS למשך שנה. <strong>יש להפעיל רק כאשר HTTPS יציב</strong> - דפדפנים שומרים זאת במטמון וקשה לבטל. נשלח רק דרך HTTPS."

msgid "HSTS: includeSubDomains; preload"
msgstr "HSTS: includeSubDomains; preload"

msgid "Extends HSTS to <strong>every subdomain</strong> and marks the site for browser preload lists (near-permanent). Only with HSTS on, and only if every subdomain is HTTPS."
msgstr "מרחיב את HSTS <strong>לכל תת-דומיין</strong> ומסמן את האתר לרשימות הטעינה מראש של הדפדפנים (כמעט קבוע). רק כאשר HSTS פעיל, ורק אם כל תת-דומיין מוגש ב-HTTPS."

msgid "SVG uploads"
msgstr "העלאות SVG"

msgid "Allow SVG uploads"
msgstr "אפשר העלאות SVG"

msgid "Every SVG is sanitised on upload (scripts, event handlers and external references are stripped). Allowed only for users with the <code>%s</code> capability."
msgstr "כל קובץ SVG מנוקה בעת ההעלאה (סקריפטים, מטפלי אירועים והפניות חיצוניות מוסרים). מותר רק למשתמשים בעלי ההרשאה <code>%s</code>."

msgid "Hide WordPress version"
msgstr "הסתרת גרסת וורדפרס"

msgid "Remove version info"
msgstr "הסרת מידע גרסה"

msgid "Removes the generator meta tag/RSS marker and the <code>?ver=</code> WordPress version from core asset URLs. Plugin and theme asset versions are kept, so cache-busting still works."
msgstr "מסיר את תג ה-generator/סימון ה-RSS ואת גרסת וורדפרס <code>?ver=</code> מכתובות של קבצי ליבה. גרסאות של קבצי תוספים וערכות עיצוב נשמרות, כך שביטול מטמון עדיין עובד."

msgid "Elementor"
msgstr "Elementor"

msgid "Elementor is not active on this site right now - these tweaks apply only when it is."
msgstr "אלמנטור אינו פעיל באתר זה כרגע - התאמות אלה חלות רק כשהוא פעיל."

msgid "Disable Elementor Google Fonts"
msgstr "השבתת Google Fonts של אלמנטור"

msgid "Stops Elementor loading fonts from Google (privacy/performance). Use only if your fonts are hosted locally."
msgstr "מונע מאלמנטור לטעון גופנים מ-Google (פרטיות/ביצועים). יש להשתמש רק אם הגופנים שלך מאוחסנים מקומית."

msgid "Validate phone fields (Elementor Pro)"
msgstr "אימות שדות טלפון (Elementor Pro)"

msgid "Rejects malformed numbers in Elementor Pro form <code>tel</code> fields (9-14 digits, optional leading +)."
msgstr "דוחה מספרים שגויים בשדות <code>tel</code> של טפסי Elementor Pro (9-14 ספרות, + מוביל אופציונלי)."

msgid "Small site-wide tweaks: HTTP security headers, sanitised SVG uploads, hiding the WordPress version, and Elementor helpers. Each tweak is an independent toggle."
msgstr "התאמות קטנות לכל האתר: כותרות אבטחה של HTTP, העלאות SVG מנוקות, הסתרת גרסת וורדפרס, ועזרים לאלמנטור. כל התאמה היא מתג עצמאי."

msgid "You are not allowed to upload SVG files."
msgstr "אין לך הרשאה להעלות קובצי SVG."

msgid "This SVG could not be sanitised and was not uploaded."
msgstr "לא ניתן היה לנקות את קובץ ה-SVG והוא לא הועלה."

msgid "Please enter a valid phone number."
msgstr "נא להזין מספר טלפון תקין."

msgid "Post not found."
msgstr "הפוסט לא נמצא."

msgid "Duplicate Post"
msgstr "שכפול פוסטים"

msgid "Duplicate \"%s\""
msgstr "שכפול \"%s\""

msgid "Duplicate"
msgstr "שכפול"

msgid "Duplicate \"%s\" and edit the copy"
msgstr "שכפול \"%s\" ועריכת העותק"

msgid "Duplicate & Edit"
msgstr "שכפול ועריכה"

msgid "You are not allowed to duplicate this item."
msgstr "אין לך הרשאה לשכפל פריט זה."

msgid "Item duplicated as a draft."
msgstr "הפריט שוכפל כטיוטה."

msgid "%d items duplicated as drafts."
msgstr "%d פריטים שוכפלו כטיוטות."

msgid "Adds \"Duplicate\" and \"Duplicate & Edit\" links to the post lists, plus a bulk action. Copies are created as drafts, including custom fields (Elementor data), taxonomies and the featured image."
msgstr "מוסיף קישורי \"שכפול\" ו\"שכפול ועריכה\" לרשימות התוכן, וכן פעולה קבוצתית. עותקים נוצרים כטיוטות, כולל שדות מותאמים (נתוני אלמנטור), טקסונומיות ותמונה ראשית."

msgid "Duplication Settings"
msgstr "הגדרות שכפול"

msgid "Enabled post types"
msgstr "סוגי תוכן פעילים"

msgid "Title suffix"
msgstr "סיומת לכותרת"

msgid "Appended to the copy's title. Leave empty for an identical title."
msgstr "מתווספת לכותרת העותק. השאירו ריק לכותרת זהה."

msgid "Copy custom fields"
msgstr "העתקת שדות מותאמים"

msgid "Includes the featured image, page template and page-builder data (Elementor)."
msgstr "כולל תמונה ראשית, תבנית עמוד ונתוני בוני עמודים (אלמנטור)."

msgid "Copy taxonomies"
msgstr "העתקת טקסונומיות"

msgid "Categories, tags and custom taxonomies."
msgstr "קטגוריות, תגיות וטקסונומיות מותאמות."

msgid "Keep original date"
msgstr "שמירת התאריך המקורי"

msgid "Off = the copy gets the current date."
msgstr "כבוי = העותק מקבל את התאריך הנוכחי."

msgid "One-click duplication of posts, pages and custom post types as drafts - including custom fields (Elementor data), taxonomies and the featured image."
msgstr "שכפול בקליק אחד של פוסטים, עמודים וסוגי תוכן מותאמים כטיוטות - כולל שדות מותאמים (נתוני אלמנטור), טקסונומיות ותמונה ראשית."

msgid "Update Emails"
msgstr "מיילים על עדכונים"

msgid "Silences the \"site updated\" email notifications WordPress sends after automatic plugin, theme and core updates. Failure emails are always kept."
msgstr "משתיק את הודעות המייל \"האתר עודכן\" שוורדפרס שולח אחרי עדכונים אוטומטיים של תוספים, תבניות והליבה. מיילים על כשלים תמיד נשלחים."

msgid "WordPress emails the site admin after every automatic update. On a maintained site these routine \"success\" notifications are noise - this module silences them. Emails about FAILED updates are never suppressed."
msgstr "וורדפרס שולח מייל למנהל האתר אחרי כל עדכון אוטומטי. באתר מתוחזק ההודעות השגרתיות על הצלחה הן רעש - המודול הזה משתיק אותן. מיילים על עדכונים שנכשלו לעולם לא מושתקים."

msgid "Silence notifications for"
msgstr "השתקת הודעות עבור"

msgid "Plugin auto-updates"
msgstr "עדכוני תוספים אוטומטיים"

msgid "Theme auto-updates"
msgstr "עדכוני תבניות אוטומטיים"

msgid "Core auto-updates (successful only)"
msgstr "עדכוני ליבה אוטומטיים (מוצלחים בלבד)"

msgid "Failure and critical core-update emails always go out."
msgstr "מיילים על כשלים ועדכוני ליבה קריטיים תמיד נשלחים."

msgid "Hide Login"
msgstr "הסתרת התחברות"

msgid "That slug is empty, invalid or reserved by WordPress - the previous slug was kept."
msgstr "הסלאג ריק, לא תקין או שמור על ידי וורדפרס - הסלאג הקודם נשמר."

msgid "Moves the login page to a custom URL. The default wp-login.php returns a 404 page and logged-out visitors of wp-admin are sent to a 404 as well."
msgstr "מעביר את עמוד ההתחברות לכתובת מותאמת אישית. wp-login.php הרגיל מחזיר עמוד 404, וגולשים לא מחוברים שנכנסים ל-wp-admin מופנים גם הם ל-404."

msgid "Login URL"
msgstr "כתובת התחברות"

msgid "Login slug"
msgstr "סלאג התחברות"

msgid "Lowercase letters, digits, dashes and underscores only. WordPress core slugs are rejected."
msgstr "אותיות לטיניות קטנות, ספרות, מקפים וקווים תחתונים בלבד. סלאגים השמורים לליבת וורדפרס נדחים."

msgid "Current login URL"
msgstr "כתובת ההתחברות הנוכחית"

msgid "Bookmark this URL - wp-login.php will stop working while this module is enabled."
msgstr "שמרו את הכתובת הזו בסימניות - wp-login.php יפסיק לעבוד כל עוד המודול פעיל."

msgid "Moves the login page to a custom URL and returns a 404 for wp-login.php and logged-out wp-admin requests. Replaces the WPS Hide Login plugin."
msgstr "מעביר את עמוד ההתחברות לכתובת מותאמת אישית ומחזיר 404 עבור wp-login.php ועבור בקשות wp-admin של גולשים לא מחוברים. מחליף את התוסף WPS Hide Login."

msgid "Enlighter"
msgstr "Enlighter"

msgid "Syntax-highlight code on the front end. Insert code with the \"Code (Enlighter)\" block, the [dpt_code lang=\"php\"]…[/dpt_code] shortcode, or the Elementor widget. Optionally highlight every existing pre/code block automatically."
msgstr "הדגשת תחביר של קוד בצד הלקוח. הכניסו קוד באמצעות הבלוק \"קוד (Enlighter)\", השורטקוד [dpt_code lang=\"php\"]…[/dpt_code], או הווידג'ט של אלמנטור. אפשר גם להדגיש אוטומטית כל בלוק pre/code קיים."

msgid "Appearance"
msgstr "מראה"

msgid "Theme"
msgstr "ערכת נושא"

msgid "Auto (follow visitor)"
msgstr "אוטומטי (לפי המבקר)"

msgid "Light"
msgstr "בהיר"

msgid "Dark"
msgstr "כהה"

msgid "Line numbers"
msgstr "מספרי שורות"

msgid "Copy button"
msgstr "כפתור העתקה"

msgid "Auto-highlight pre/code"
msgstr "הדגשה אוטומטית של pre/code"

msgid "Highlight every existing <pre><code> block, detecting the language from its class (e.g. language-php)."
msgstr "הדגשת כל בלוק <pre><code> קיים, עם זיהוי השפה מתוך המחלקה שלו (למשל language-php)."

msgid "Syntax-highlight code with a block, the [dpt_code] shortcode, automatic pre/code highlighting and an Elementor widget. Replaces the Enlighter plugin."
msgstr "הדגשת תחביר של קוד באמצעות בלוק, השורטקוד [dpt_code], הדגשה אוטומטית של pre/code וווידג'ט אלמנטור. מחליף את התוסף Enlighter."

msgid "Copy"
msgstr "העתקה"

msgid "Copied"
msgstr "הועתק"

msgid "Code (Enlighter)"
msgstr "קוד (Enlighter)"

msgid "Code"
msgstr "קוד"

msgid "Language"
msgstr "שפה"

msgid "WooCommerce Checkout"
msgstr "צ׳קאאוט WooCommerce"

msgid "Checkout helpers for WooCommerce: suggest corrections for mistyped email domains, and validate Israeli phone numbers (client-side hint plus a server-side check)."
msgstr "עזרים לצ׳קאאוט של WooCommerce: הצעת תיקונים לדומייני אימייל שהוקלדו בטעות, ואימות מספרי טלפון ישראליים (רמז בצד הלקוח יחד עם בדיקה בצד השרת)."

msgid "Did you mean %s?"
msgstr "האם התכוונת ל-%s?"

msgid "The number is %1$d digit(s) short for a number starting with %2$s."
msgstr "חסרות %1$d ספרות במספר שמתחיל ב-%2$s."

msgid "The number has %1$d digit(s) too many for a number starting with %2$s."
msgstr "יש %1$d ספרות מיותרות במספר שמתחיל ב-%2$s."

msgid "The phone number must start with 05, 972 or +972."
msgstr "מספר הטלפון חייב להתחיל ב-05, 972 או +972."

msgid "A phone number starting with +972 must contain 13 digits."
msgstr "מספר טלפון שמתחיל ב-+972 חייב להכיל 13 ספרות."

msgid "A phone number starting with 972 must contain 12 digits."
msgstr "מספר טלפון שמתחיל ב-972 חייב להכיל 12 ספרות."

msgid "A phone number starting with 05 must contain 10 digits."
msgstr "מספר טלפון שמתחיל ב-05 חייב להכיל 10 ספרות."

msgid "Checkout helpers: suggest fixes for mistyped email domains, and validate Israeli phone numbers."
msgstr "עזרים לצ׳קאאוט: הצעת תיקונים לדומייני אימייל שהוקלדו בטעות, ואימות מספרי טלפון ישראליים."

msgid "WooCommerce is not active on this site right now - these helpers apply only when it is."
msgstr "WooCommerce אינו פעיל באתר זה כרגע - העזרים האלה חלים רק כשהוא פעיל."

msgid "Email suggestions"
msgstr "הצעות אימייל"

msgid "Suggest email fixes"
msgstr "הצעת תיקוני אימייל"

msgid "When a customer types an email whose domain looks like a typo of a known provider, offer a one-click correction."
msgstr "כאשר לקוח מקליד אימייל שהדומיין שלו נראה כשגיאת הקלדה של ספק מוכר, מוצע תיקון בלחיצה אחת."

msgid "Known email domains"
msgstr "דומייני אימייל מוכרים"

msgid "One domain per line. Typos of these are what trigger a suggestion. Leave empty to restore the default list."
msgstr "דומיין אחד בכל שורה. שגיאות הקלדה של אלה הן שמפעילות הצעה. יש להשאיר ריק כדי לשחזר את רשימת ברירת המחדל."

msgid "Phone validation"
msgstr "אימות טלפון"

msgid "Validate Israeli phone numbers"
msgstr "אימות מספרי טלפון ישראליים"

msgid "Accepts numbers starting with 05 (10 digits), 972 (12) or +972 (13). Checked both in the browser and on the server, so checkout is blocked on an invalid number."
msgstr "מקבל מספרים שמתחילים ב-05 (10 ספרות), 972 (12) או +972 (13). נבדק גם בדפדפן וגם בשרת, כך שהצ׳קאאוט נחסם במספר לא תקין."

msgid "Disable Comments"
msgstr "כיבוי תגובות"

msgid "Turns off comments globally or per post type - closes forms, hides existing comments and removes the admin comments UI. WooCommerce product reviews are protected by default."
msgstr "מכבה תגובות גלובלית או לפי סוג תוכן - סוגר טפסים, מסתיר תגובות קיימות ומסיר את ממשק התגובות באדמין. ביקורות מוצר של ווקומרס מוגנות כברירת מחדל."

msgid "Closes comment forms, hides existing comments and removes the admin comments UI (menu, admin-bar bubble, dashboard widget, edit-comments screen). The admin UI is removed only when comments are disabled for every relevant post type."
msgstr "סוגר טפסי תגובה, מסתיר תגובות קיימות ומסיר את ממשק התגובות באדמין (תפריט, בועית סרגל העליון, ווידג'ט לוח הבקרה ומסך התגובות). ממשק האדמין מוסר רק כשהתגובות כבויות לכל סוגי התוכן הרלוונטיים."

msgid "Where to disable comments"
msgstr "איפה לכבות תגובות"

msgid "Mode"
msgstr "מצב"

msgid "Everywhere (all post types)"
msgstr "בכל מקום (כל סוגי התוכן)"

msgid "Only on selected post types"
msgstr "רק בסוגי תוכן נבחרים"

msgid "Selected post types"
msgstr "סוגי תוכן נבחרים"

msgid "Used only in \"Only on selected post types\" mode."
msgstr "בשימוש רק במצב \"רק בסוגי תוכן נבחרים\"."

msgid "Keep WooCommerce product reviews"
msgstr "שמירת ביקורות מוצר של ווקומרס"

msgid "Product reviews are technically comments - this keeps them working even when comments are disabled everywhere else."
msgstr "ביקורות מוצר הן טכנית תגובות - האפשרות הזו משאירה אותן פעילות גם כשהתגובות כבויות בכל שאר האתר."

msgid "(WooCommerce is not active on this site right now.)"
msgstr "(ווקומרס לא פעיל באתר הזה כרגע.)"

msgid "Content Control"
msgstr "בקרת תוכן"

msgid "Who can view this?"
msgstr "מי יכול לצפות בזה?"

msgid "Everyone"
msgstr "כולם"

msgid "Logged-in users"
msgstr "משתמשים מחוברים"

msgid "Logged-out visitors only"
msgstr "מבקרים לא מחוברים בלבד"

msgid "Specific roles"
msgstr "תפקידים מסוימים"

msgid "Roles (used with \"Specific roles\"):"
msgstr "תפקידים (בשימוש עם \"תפקידים מסוימים\"):"

msgid "Custom restriction message"
msgstr "הודעת הגבלה מותאמת"

msgid "Shown in place of the content. Leave blank to use the global default."
msgstr "מוצגת במקום התוכן. השאירו ריק כדי להשתמש בברירת המחדל הכללית."

msgid "Content Control visibility"
msgstr "נראות בקרת תוכן"

msgid "Logged-out visitors"
msgstr "מבקרים לא מחוברים"

msgid "Roles (comma-separated keys, for \"Specific roles\")"
msgstr "תפקידים (מפתחות מופרדים בפסיקים, עבור \"תפקידים מסוימים\")"

msgid "Restrict pages and posts by role, hide menu items, gate content with a shortcode, and protect the whole site behind login. Replaces the Content Control plugin."
msgstr "הגבלת עמודים ופוסטים לפי תפקיד, הסתרת פריטי תפריט, חסימת תוכן באמצעות שורטקוד, והגנה על כל האתר מאחורי התחברות. מחליף את התוסף Content Control."

msgid "This site is private."
msgstr "האתר הזה פרטי."

msgid "Private site"
msgstr "אתר פרטי"

msgid "Protect the whole site behind login and set the default restriction message. Per-page restrictions and per-menu-item visibility are set on each page and menu item; wrap partial content with the [dpt_restrict] shortcode."
msgstr "הגנה על כל האתר מאחורי התחברות והגדרת הודעת ההגבלה המוגדרת כברירת מחדל. הגבלות פר-עמוד ונראות פר-פריט תפריט נקבעות בכל עמוד ופריט תפריט; עטפו תוכן חלקי בשורטקוד [dpt_restrict]."

msgid "Whole-site protection"
msgstr "הגנה על כל האתר"

msgid "Off - the site is public"
msgstr "כבוי - האתר ציבורי"

msgid "Require login for the whole site"
msgstr "דרישת התחברות לכל האתר"

msgid "Require one of these roles"
msgstr "דרישת אחד מהתפקידים האלה"

msgid "Allowed roles"
msgstr "תפקידים מורשים"

msgid "Used only in \"Require one of these roles\" mode. Administrators always have access."
msgstr "בשימוש רק במצב \"דרישת אחד מהתפקידים האלה\". למנהלים תמיד יש גישה."

msgid "When access is denied"
msgstr "כאשר הגישה נדחית"

msgid "Redirect to the login form"
msgstr "הפניה לטופס ההתחברות"

msgid "Redirect to a page"
msgstr "הפניה לעמוד"

msgid "Show a message"
msgstr "הצגת הודעה"

msgid "Redirect page"
msgstr "עמוד הפניה"

msgid "— none —"
msgstr "— ללא —"

msgid "Used with \"Redirect to a page\". This page is always reachable."
msgstr "בשימוש עם \"הפניה לעמוד\". העמוד הזה תמיד נגיש."

msgid "Private-site message"
msgstr "הודעת אתר פרטי"

msgid "Always-allowed page IDs"
msgstr "מזהי עמודים מורשים תמיד"

msgid "Comma-separated page/post IDs reachable even while the site is protected."
msgstr "מזהי עמודים/פוסטים מופרדים בפסיקים שנגישים גם כשהאתר מוגן."

msgid "Default restriction message"
msgstr "הודעת הגבלה ברירת מחדל"

msgid "Message"
msgstr "הודעה"

msgid "Shown in place of restricted page/post content when no per-page message is set."
msgstr "מוצגת במקום תוכן עמוד/פוסט מוגבל כשלא הוגדרה הודעה פר-עמוד."

msgid "This content is restricted."
msgstr "התוכן הזה מוגבל."

msgid "Invalid role key."
msgstr "מפתח תפקיד לא תקין."

msgid "A role with that key already exists."
msgstr "כבר קיים תפקיד עם המפתח הזה."

msgid "Role display name is required."
msgstr "שם תצוגה לתפקיד הוא שדה חובה."

msgid "Could not create the role."
msgstr "לא ניתן היה ליצור את התפקיד."

msgid "That role cannot be deleted."
msgstr "לא ניתן למחוק את התפקיד הזה."

msgid "Role not found."
msgstr "התפקיד לא נמצא."

msgid "This is the default role for new users - change the default role first."
msgstr "זהו תפקיד ברירת המחדל למשתמשים חדשים - שנו קודם את תפקיד ברירת המחדל."

msgid "Choose a valid role to move existing users to."
msgstr "בחרו תפקיד תקין להעברת המשתמשים הקיימים אליו."

msgid "You cannot delete a role that grants your own administrator access."
msgstr "לא ניתן למחוק תפקיד שמעניק לך את גישת הניהול שלך עצמך."

msgid "Invalid capability name."
msgstr "שם הרשאה לא תקין."

msgid "That name is reserved (a role key or level_N) and cannot be used as a capability."
msgstr "השם הזה שמור (מפתח תפקיד או level_N) ולא ניתן להשתמש בו כהרשאה."

msgid "User Role Editor"
msgstr "עורך תפקידי משתמש"

msgid "Changes saved."
msgstr "השינויים נשמרו."

msgid "Edit exactly what each role can do. The administrator role always keeps the capabilities needed to manage the site, and you can never remove your own access."
msgstr "עריכה מדויקת של מה שכל תפקיד יכול לעשות. תפקיד המנהל תמיד שומר על ההרשאות הנדרשות לניהול האתר, ולעולם לא ניתן להסיר את הגישה שלך עצמך."

msgid "Choose a role"
msgstr "בחירת תפקיד"

msgid "Load"
msgstr "טעינה"

msgid "Capabilities for: %s"
msgstr "הרשאות עבור: %s"

msgid "Select / deselect all"
msgstr "בחירה / ביטול בחירה של הכול"

msgid "custom"
msgstr "מותאם"

msgid "Save Capabilities"
msgstr "שמירת הרשאות"

msgid "Add a role"
msgstr "הוספת תפקיד"

msgid "Role key"
msgstr "מפתח תפקיד"

msgid "Lowercase letters, digits and underscores."
msgstr "אותיות לטיניות קטנות, ספרות וקווים תחתונים."

msgid "Display name"
msgstr "שם תצוגה"

msgid "Copy capabilities from"
msgstr "העתקת הרשאות מ"

msgid "— none (empty role) —"
msgstr "— ללא (תפקיד ריק) —"

msgid "Add Role"
msgstr "הוספת תפקיד"

msgid "Delete a role"
msgstr "מחיקת תפקיד"

msgid "Delete this role and move its users to the selected role?"
msgstr "למחוק את התפקיד ולהעביר את המשתמשים שלו לתפקיד הנבחר?"

msgid "Role to delete"
msgstr "תפקיד למחיקה"

msgid "Move its users to"
msgstr "העברת המשתמשים שלו אל"

msgid "Delete Role"
msgstr "מחיקת תפקיד"

msgid "Add a custom capability"
msgstr "הוספת הרשאה מותאמת"

msgid "Capability name"
msgstr "שם הרשאה"

msgid "Grant to roles"
msgstr "הענקה לתפקידים"

msgid "Add Capability"
msgstr "הוספת הרשאה"

msgid "Edit the capabilities of every role, add, clone or delete roles, and register custom capabilities. Replaces the User Role Editor plugin."
msgstr "עריכת ההרשאות של כל תפקיד, הוספה, שכפול או מחיקה של תפקידים, ורישום הרשאות מותאמות אישית. מחליף את התוסף User Role Editor."

msgid "Rank Math Breadcrumbs"
msgstr "פירורי לחם Rank Math"

msgid "Adds a Blog crumb on post pages and a Shop crumb on WooCommerce product pages to the Rank Math breadcrumb trail. URLs are detected automatically and can be overridden."
msgstr "מוסיף פירור \"בלוג\" בעמודי פוסטים ופירור \"חנות\" בעמודי מוצרים של WooCommerce לשביל פירורי הלחם של Rank Math. הכתובות מזוהות אוטומטית וניתן לעקוף אותן."

msgid "Blog"
msgstr "בלוג"

msgid "Shop"
msgstr "חנות"

msgid "Adds a Blog crumb on post pages and a Shop crumb on product pages to the Rank Math breadcrumb trail. Leave a URL or label empty to detect it automatically."
msgstr "מוסיף פירור \"בלוג\" בעמודי פוסטים ופירור \"חנות\" בעמודי מוצרים לשביל פירורי הלחם של Rank Math. יש להשאיר כתובת או תווית ריקה כדי לזהות אותה אוטומטית."

msgid "Rank Math is not active on this site right now - these crumbs apply only when it is."
msgstr "Rank Math אינו פעיל באתר זה כרגע - הפירורים האלה חלים רק כשהוא פעיל."

msgid "Blog crumb"
msgstr "פירור בלוג"

msgid "Add a Blog crumb"
msgstr "הוספת פירור בלוג"

msgid "Shown on single posts and blog archives (category, tag, author, date)."
msgstr "מוצג בפוסטים בודדים ובארכיוני בלוג (קטגוריה, תגית, מחבר, תאריך)."

msgid "Label"
msgstr "תווית"

msgid "Blog (auto)"
msgstr "בלוג (אוטומטי)"

msgid "URL"
msgstr "כתובת"

msgid "Auto-detected: %s"
msgstr "זוהה אוטומטית: %s"

msgid "No posts page is set under Settings > Reading, so enter the blog URL manually."
msgstr "לא הוגדר עמוד פוסטים תחת הגדרות > קריאה, לכן יש להזין את כתובת הבלוג ידנית."

msgid "Shop crumb"
msgstr "פירור חנות"

msgid "WooCommerce is not active - the Shop crumb applies to product pages only."
msgstr "WooCommerce אינו פעיל - פירור החנות חל על עמודי מוצר בלבד."

msgid "Add a Shop crumb"
msgstr "הוספת פירור חנות"

msgid "Shown on single WooCommerce product pages."
msgstr "מוצג בעמודי מוצר בודדים של WooCommerce."

msgid "Shop (auto)"
msgstr "חנות (אוטומטי)"

msgid "No WooCommerce shop page detected - enter the shop URL manually if needed."
msgstr "לא זוהה עמוד חנות של WooCommerce - יש להזין את כתובת החנות ידנית במידת הצורך."

msgid "API key"
msgstr "מפתח API"

msgid "Add an API key and a valid sender address first - until then emails go through the default WordPress mailer."
msgstr "יש להזין קודם מפתח API וכתובת שולח תקינה - עד אז המיילים נשלחים דרך מנגנון השליחה הרגיל של וורדפרס."

msgid "Always send from the address above, even when another plugin sets its own From address. Recommended - Resend only accepts verified senders."
msgstr "לשלוח תמיד מהכתובת שלמעלה, גם כשתוסף אחר מגדיר כתובת שולח משלו. מומלץ - Resend מקבל רק שולחים מאומתים."

msgid "Behavior"
msgstr "התנהגות"

msgid "Bounced"
msgstr "הוחזר (Bounce)"

msgid "Clear log"
msgstr "ניקוי יומן"

msgid "Clicked"
msgstr "נלחץ"

msgid "Create a key in the Resend dashboard under API Keys. Leave empty to keep the saved key."
msgstr "יש ליצור מפתח בלוח הבקרה של Resend תחת API Keys. השאירו ריק כדי לשמור על המפתח הקיים."

msgid "Default Reply-To"
msgstr "כתובת Reply-To ברירת מחדל"

msgid "Defined by the DPT_RESEND_API_KEY constant in wp-config.php - it overrides anything entered here."
msgstr "מוגדר על ידי הקבוע DPT_RESEND_API_KEY בקובץ wp-config.php - הוא גובר על כל מה שמוזן כאן."

msgid "Delayed"
msgstr "מתעכב"

msgid "Delivered"
msgstr "נמסר"

msgid "Delivers all site email (wp_mail) through the Resend API - verified-domain sending, a send log with delivery statuses, and automatic fallback to the default mailer on errors. Replaces WP Mail SMTP / FluentSMTP."
msgstr "שולח את כל המיילים של האתר (wp_mail) דרך ה-API של Resend - שליחה מדומיין מאומת, יומן שליחות עם סטטוסי מסירה, וחזרה אוטומטית למנגנון השליחה הרגיל בשגיאות. מחליף את WP Mail SMTP / FluentSMTP."

msgid "Delivery webhook (optional)"
msgstr "Webhook מסירה (אופציונלי)"

msgid "Endpoint URL"
msgstr "כתובת ה-Endpoint"

msgid "Enter a valid email address for the test."
msgstr "יש להזין כתובת אימייל תקינה לבדיקה."

msgid "Failed"
msgstr "נכשל"

msgid "Fallback on errors"
msgstr "חזרה למנגנון הרגיל בשגיאות"

msgid "Fell back to default mailer"
msgstr "נשלח דרך המנגנון הרגיל"

msgid "Force sender"
msgstr "כפיית שולח"

msgid "Forget the saved key"
msgstr "שכחת המפתח השמור"

msgid "From email"
msgstr "אימייל שולח"

msgid "From name"
msgstr "שם שולח"

msgid "If the Resend API returns an error, hand the email to the default WordPress mailer instead of dropping it."
msgstr "אם ה-API של Resend מחזיר שגיאה, המייל מועבר למנגנון השליחה הרגיל של וורדפרס במקום ללכת לאיבוד."

msgid "If you are reading it, delivery works."
msgstr "אם אתם קוראים את זה - השליחה עובדת."

msgid "Keep the last %d sends with their delivery status."
msgstr "שמירת %d השליחות האחרונות עם סטטוס המסירה שלהן."

msgid "Lets the send log show what happened after the send: delivered, bounced, opened, marked as spam. In the Resend dashboard add a webhook pointing at the URL below, pick the email events, then paste its signing secret here."
msgstr "מאפשר ליומן השליחות להציג מה קרה אחרי השליחה: נמסר, הוחזר, נפתח, סומן כספאם. בלוח הבקרה של Resend הוסיפו webhook שמצביע לכתובת שלמטה, בחרו את אירועי האימייל, והדביקו כאן את סוד החתימה שלו."

msgid "Marked as spam"
msgstr "סומן כספאם"

msgid "Must be an address on a domain you verified in Resend (Domains screen), otherwise the API rejects every email."
msgstr "חייבת להיות כתובת בדומיין שאומת ב-Resend (מסך Domains), אחרת ה-API ידחה כל מייל."

msgid "No emails logged yet."
msgstr "עוד לא נרשמו מיילים ביומן."

msgid "Opened"
msgstr "נפתח"

msgid "Optional. Used when the email does not carry its own Reply-To header."
msgstr "אופציונלי. משמש כשלמייל אין כותרת Reply-To משלו."

msgid "Resend API"
msgstr "Resend API"

msgid "Resend Mail"
msgstr "Resend Mail"

msgid "Resend Mail test from %s"
msgstr "בדיקת Resend Mail מהאתר %s"

msgid "Send a test email"
msgstr "שליחת מייל בדיקה"

msgid "Send log"
msgstr "יומן שליחות"

msgid "Send log cleared."
msgstr "יומן השליחות נוקה."

msgid "Send test"
msgstr "שליחת בדיקה"

msgid "Sends every email this site generates (wp_mail) through the Resend API instead of the server's PHP mailer. Deactivate any other SMTP plugin - two mailers will fight over the same emails."
msgstr "שולח כל מייל שהאתר מייצר (wp_mail) דרך ה-API של Resend במקום שרת ה-PHP. יש לכבות כל תוסף SMTP אחר - שני מנגנוני שליחה יתנגשו על אותם מיילים."

msgid "Sent"
msgstr "נשלח"

msgid "Signing secret"
msgstr "סוד חתימה"

msgid "Status"
msgstr "סטטוס"

msgid "Subject"
msgstr "נושא"

msgid "Test email sent - check the inbox and the log below."
msgstr "מייל הבדיקה נשלח - בדקו את תיבת הדואר ואת היומן למטה."

msgid "The test email failed to send. Check the log below for the error."
msgstr "שליחת מייל הבדיקה נכשלה. בדקו את השגיאה ביומן למטה."

msgid "This is a test email sent through the Resend API by the Digitizer Pro Tools plugin."
msgstr "זהו מייל בדיקה שנשלח דרך ה-API של Resend על ידי התוסף Digitizer Pro Tools."

msgid "Time"
msgstr "זמן"

msgid "To"
msgstr "אל"

msgid "Unsigned webhook calls are rejected while this is empty."
msgstr "כל עוד השדה ריק, קריאות webhook לא חתומות נדחות."

msgid "The Resend API rejected the test email - it went out through the default WordPress mailer instead. Check the log below for the error."
msgstr "ה-API של Resend דחה את מייל הבדיקה - הוא נשלח דרך מנגנון השליחה הרגיל של וורדפרס במקום. בדקו את השגיאה ביומן למטה."
