msgstr "טקסטים של הכפתור הצף"

msgid "Button content"
msgstr "תוכן הכפתור"

msgid "Leave empty for the built-in cookie icon, or type short text of your own."
msgstr "השאירו ריק לאייקון העוגייה המובנה, או הקלידו טקסט קצר משלכם."

msgid "Button label (accessibility)"
msgstr "תווית הכפתור (נגישות)"

msgid "Privacy policy link (shared for all languages)"
msgstr "קישור מדיניות פרטיות (משותף לכל השפות)"

msgid "Privacy policy page"
msgstr "עמוד מדיניות פרטיות"

msgid "— No link —"
msgstr "— ללא קישור —"

msgid "Pick the privacy policy page. With WPML or Polylang, the translated page is linked automatically per language."
msgstr "בחרו את עמוד מדיניות הפרטיות. עם WPML או Polylang, העמוד המתורגם מקושר אוטומטית לפי שפה."

msgid "Or an external URL (instead of a page)"
msgstr "או כתובת URL חיצונית (במקום עמוד)"

msgid "Only if the policy lives outside this site. Leave empty when a page is selected above."
msgstr "רק אם המדיניות נמצאת מחוץ לאתר זה. השאירו ריק כשנבחר עמוד למעלה."

msgid "Default language"
msgstr "שפת ברירת מחדל"

msgid "Used when the page locale has no matching language."
msgstr "בשימוש כששפת העמוד לא תואמת לאף שפה מוגדרת."

msgid "Manage languages"
msgstr "ניהול שפות"

msgid "Add language (code):"
msgstr "הוספת שפה (קוד):"

